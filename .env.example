# Copy this file to .env and fill in your values.
# python-dotenv will load it automatically on startup.

# ─── Required ──────────────────────────────────────────────────────────────────
# Path to your GCP service account JSON key (for Cloud Vision API)
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\gcp-key.json

# ─── Optional (defaults shown) ────────────────────────────────────────────────
# Upscale long edge to this many pixels (larger = better small-text OCR)
PREPROCESS_TARGET_SIZE=1600

# CLAHE clip limit: 1.5–2.5 is safe; higher = more aggressive contrast boost
CLAHE_CLIP_LIMIT=2.0

# NL-Means denoising strength (h parameter): 3–8 recommended
DENOISE_H=6

# Minimum RapidFuzz score (0–100) to accept a medicine name match
FUZZY_MIN_SCORE=70

# Server bind settings
API_HOST=0.0.0.0
API_PORT=8000
